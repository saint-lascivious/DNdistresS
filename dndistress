HELP_REQUEST=0
HELP_TOPIC=""
HELP_AMBIGUOUS=0

add_help_topic() {
    t="$1"

    [ -n "$t" ] || return 0

    if [ -z "$HELP_TOPIC" ]; then
        HELP_TOPIC="$t"
        return 0
    fi

    [ "$HELP_TOPIC" = "$t" ] && return 0

    HELP_AMBIGUOUS=1
}

scan_help_request() {
    HELP_REQUEST=0
    HELP_TOPIC="${HELP_TOPIC:-}"
    HELP_AMBIGUOUS=0

    for tok in "$@"; do

        case "$tok" in
            -h|h|--help|help)
                HELP_REQUEST=1
                break
                ;;
        esac

    done

    [ "$HELP_REQUEST" -eq 1 ] || return 0

    for tok in "$@"; do

        case "$tok" in
            -h|h|--help|help)
                continue
                ;;
        esac

        if t="$(canonical_help_topic "$tok" 2>/dev/null)"; then

            add_help_topic "$t"

        fi

    done

    [ -n "$HELP_TOPIC" ] || HELP_TOPIC="general"

}

do_dndistress() {

    scan_help_request "$@"

    if [ "$HELP_REQUEST" -eq 1 ]; then

        [ "$HELP_AMBIGUOUS" -eq 0 ] || { log 1 "${RED}ambiguous help request (multiple topics)${N_C}"

            exit_with_status 2

        }

        show_help_topic "$HELP_TOPIC" | page_output

        exit 0
    fi

