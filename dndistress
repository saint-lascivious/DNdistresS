log() {
    lvl="${1:-3}"

    shift || true

    msg="${*:-}"

    case "$lvl" in
        0|critical|CRITICAL)
            n=0
            pfx="${L_GREY}[${BOLD}${RED}!${N_C}${L_GREY}]${N_C}"
            pri="user.crit"
            ;;
        1|error|ERROR)
            n=1
            pfx="${L_GREY}[${RED}✗${L_GREY}]${N_C}"
            pri="user.err"
            ;;
        2|warning|WARNING|warn|WARN)
            n=2
            pfx="${L_GREY}[${YELLOW}!${L_GREY}]${N_C}"
            pri="user.warning"
            ;;
        3|info|INFO)
            n=3
            pfx="${L_GREY}[${BLUE}i${L_GREY}]${N_C}"
            pri="user.info"
            ;;
        4|debug|DEBUG)
            n=4
            pfx="${L_GREY}[${GREY}•${L_GREY}]${N_C}"
            pri="user.debug"
            ;;
        5|trace|TRACE)
            n=5
            pfx="${L_GREY}[${GREY}…${L_GREY}]${N_C}"
            pri="user.debug"
            ;;
        *)
            n=3
            pfx="${L_GREY}[${BLUE}?${L_GREY}]${N_C}"
            pri="user.info"
            msg="${CYAN}${msg}${N_C}"
            ;;
    esac

    case "${_VERBOSITY:-0}" in
        0|1|2|3|4|5)
            v="${_VERBOSITY}"
            ;;
        *)
            v=0
            ;;
    esac

    [ "$v" -ge "$n" ] || return 0

    if [ "$USE_LOGGER" -eq 1 ] && [ ! -t 2 ]; then
        clean_msg="$(printf '%s' "$msg" | sed 's/\x1B\[[0-9;]*[a-zA-Z]//g')"

        logger -t "$LOG_TAG" -p "$pri" -- "$clean_msg"

    else
        printf '%b %b\n' "$pfx" "$msg" >&2
    fi
}

