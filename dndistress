    esac

}

parse_duration() {
    raw="$1"

    case "$raw" in
        ''|*[!0-9\ smhdwy]*)
            ;;
    esac

    if is_nonnegint "$raw"; then
        printf '%s\n' "$raw"
        return 0
    fi

    result="$(printf '%s\n' "$raw" | tr '[:upper:]' '[:lower:]' | awk '
        BEGIN { total=0; ok=1 }
        {
            s=$0
            gsub(/,/, " ", s)
            gsub(/[[:space:]]+/, " ", s)
            sub(/^[[:space:]]+/, "", s)
            sub(/[[:space:]]+$/, "", s)

            if (s == "") { ok=0; exit }

            while (length(s) > 0) {
                if (s !~ /^[0-9]/) { ok=0; break }

                match(s, /^[0-9]+/)
                num = substr(s, 1, RLENGTH) + 0
                s   = substr(s, RLENGTH + 1)

                sub(/^[[:space:]]+/, "", s)

                if (s !~ /^[a-z]/) { ok=0; break }

                match(s, /^[a-z]+/)
                unit = substr(s, 1, RLENGTH)
                s    = substr(s, RLENGTH + 1)

                sub(/^[[:space:]]+/, "", s)

                if (unit == "s" || unit == "sec" || unit == "secs" \
                                || unit == "second" || unit == "seconds") {
                    total += num
                } else if (unit == "m" || unit == "min" || unit == "mins" \
                                       || unit == "minute" || unit == "minutes") {
                    total += num * 60
                } else if (unit == "h" || unit == "hr" || unit == "hrs" \
                                       || unit == "hour" || unit == "hours") {
                    total += num * 3600
                } else if (unit == "d" || unit == "day" || unit == "days") {
                    total += num * 86400
                } else if (unit == "w" || unit == "wk" || unit == "wks" \
                                       || unit == "week" || unit == "weeks") {
                    total += num * 604800
                } else if (unit == "mo" || unit == "month" || unit == "months") {
                    total += num * 2592000
                } else if (unit == "y" || unit == "yr" || unit == "yrs" \
                                       || unit == "year" || unit == "years") {
                    total += num * 31536000
                } else {
                    ok=0; break
                }
            }
        }
        END {
            if (!ok || total < 0) exit 1
            print total
        }
    ')" || return 1

    case "$result" in
        ''|*[!0-9]*)
            return 1
            ;;
    esac

    printf '%s\n' "$result"
}

is_running_under_own_service() {

    [ -n "${INVOCATION_ID:-}" ] || return 1

    [ -r "/proc/$$/cgroup" ] || return 1

    grep -q "/${UNIT_BASE}\.service" "/proc/$$/cgroup" 2>/dev/null
}

timer_period_seconds() {

    if [ -n "${_TIMER_PERIOD:-}" ]; then
        p="$(parse_duration "$_TIMER_PERIOD" 2>/dev/null || true)"

        case "$p" in
            ''|*[!0-9]*|0)
                return 1
                ;;
        esac

        printf '%s\n' "$p"
        return 0
    fi

    if need_cmd systemctl; then
        usec="$(systemctl show "${UNIT_BASE}.timer" -p OnUnitActiveUSec --value 2>/dev/null || true)"

        case "$usec" in
            ''|*[!0-9]*|0)
                ;;
            *)
                sec=$(( (usec + 999999) / 1000000 ))
                [ "$sec" -gt 0 ] || return 1
                printf '%s\n' "$sec"
                return 0
                ;;
        esac

    fi

    timer_file="$SERVICE_DIR/${UNIT_BASE}.timer"

    if [ -r "$timer_file" ]; then
        raw="$(awk -F= '
            /^[[:space:]]*OnUnitActiveSec[[:space:]]*=/ {
                v=$2
                sub(/^[[:space:]]+/, "", v)
                sub(/[[:space:]]+$/, "", v)
                print v
                exit
            }
        ' "$timer_file")"

        [ -n "$raw" ] || return 1

        sec="$(parse_duration "$raw" 2>/dev/null || true)"

        case "$sec" in
            ''|*[!0-9]*|0)
                return 1
                ;;
        esac

        printf '%s\n' "$sec"
        return 0
    fi

    return 1
}

enforce_timer_duration_guard() {

    is_running_under_own_service || return 0

    period="$(timer_period_seconds 2>/dev/null || true)"

    if [ -z "$period" ]; then
        log 2 "service context detected, but timer period could not be determined; skipping _DURATION guard"
        return 0
    fi

    if [ "$_DURATION" -eq 0 ]; then
        log 2 "_DURATION=0 under timer; clamping to timer period (${period}s)"
        _DURATION="$period"
        return 0
    fi

    if [ "$_DURATION" -gt "$period" ]; then
        log 2 "_DURATION too high for timer ($_DURATION > $period), clamping"
        _DURATION="$period"
    fi
}

