SLEEP_TINY_OK=0

if sleep 0.01 2>/dev/null; then
    SLEEP_TINY_OK=1
fi

nap() {

    if [ "$SLEEP_TINY_OK" -eq 1 ]; then
        sleep 0.01
    else
        sleep 1
    fi

}

nap_for_tokens() {
    deficit_ms="${1:-1}"

    if [ "$SLEEP_TINY_OK" -eq 1 ]; then

        if [ "$deficit_ms" -le 10 ]; then
            sleep 0.01
        elif [ "$deficit_ms" -le 20 ]; then
            sleep 0.02
        else
            sleep 0.05
        fi

    else
        sleep 1
    fi

}

start_worker_pool "$_MAXIMUM" || exit 1
log 3 "worker pool size: $_MAXIMUM"

while :; do
    now_s="$(now_ms)"
    elapsed_total=$(( (now_s - START_TS) / 1000 ))

    if [ $((now_s - DEBUG_TICK_MS)) -ge 1000 ]; then
        log 4 "loop: elapsed_s=$elapsed_total sent=$SENT mtokens=$MTOKENS budget=$((MTOKENS / 1000))"
        DEBUG_TICK_MS="$now_s"
    fi

    if [ "$_DURATION" -gt 0 ] && [ "$elapsed_total" -ge "$_DURATION" ]; then
        break
    fi

    dt_ms=$((now_s - LAST_TS))

    if [ "$dt_ms" -gt 0 ]; then
        MTOKENS=$((MTOKENS + (_QPS * dt_ms)))

        [ "$MTOKENS" -gt "$MBUCKET" ] && MTOKENS="$MBUCKET"

        LAST_TS="$now_s"
    fi

    tokq=$((MTOKENS / 1000))
    budget="$tokq"

    if [ "$budget" -le 0 ]; then
        deficit=$((1000 - MTOKENS))

        [ "$deficit" -lt 1 ] && deficit=1

        wait_ms=$(((deficit * 1000 + _QPS - 1) / _QPS))
        nap_for_tokens "$wait_ms"
        continue
    fi

    i=0

    while [ "$i" -lt "$budget" ]; do
        next_domain || break
        d="$CUR"

        [ -n "$d" ] || continue

        if ! printf '%s\n' "$d" >&4; then
            log 1 "worker queue write failed"
            break 2
        fi

        SENT=$((SENT + 1))
        MTOKENS=$((MTOKENS - 1000))
        i=$((i + 1))
    done

done

exec 3<&-
stop_worker_pool

END_MS="$(now_ms)"
ELAPSED_MS=$((END_MS - START_TS))
RUN_MS=$((END_MS - SCRIPT_START))

if [ "$ELAPSED_MS" -gt 0 ]; then
    ach_qps="$(awk -v s="$SENT" -v ms="$ELAPSED_MS" 'BEGIN { printf "%.2f", s / (ms / 1000) }')"
else
    ach_qps="0"
fi

ELAPSED_HUMAN="$(format_runtime_ms "$ELAPSED_MS")"
RUN_HUMAN="$(format_runtime_ms "$RUN_MS")"

if [ -t 1 ] && [ "$_VERBOSITY" -gt 0 ]; then
    printf '%s\n' "${SENT}q / ${ELAPSED_HUMAN} = ${ach_qps}qps, took ${RUN_HUMAN}." >&2
fi
