_MODE="none"

set_mode() {
    _req="$1"

    if [ "$_MODE" != "none" ] && [ "$_MODE" != "$_req" ]; then
        log 1 "install and uninstall are mutually exclusive"
        exit 2
    fi

    _MODE="$_req"
}

need_optarg() {
    opt="$1"

    [ "$#" -ge 2 ] || { log 1 "missing argument for $opt"; exit 2; }

}

