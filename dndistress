}

next_domain() {

    if IFS= read -r CUR <&3; then
        return 0
    fi

    if [ "$_DURATION" -eq 0 ]; then
        exec 3<&-
        exec 3< "$DOMAINS"
        IFS= read -r CUR <&3
    else
        return 1
    fi

