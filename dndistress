    [ "$_STATUS_ENABLED" = "1" ] || exit "$code"

    is_running_under_own_service || exit "$code"

    if ! mkdir -p "$_STATUS_DIR" 2>/dev/null; then

        log 1 "${RED}Failed to create status dir: ${L_GREY}$_STATUS_DIR${N_C}"

        exit "$code"
    fi

    if need_cmd flock; then
        exec 9>"$_LOCK_FILE"
        flock 9
    fi

    compute_runtime_metrics

    now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

    umask 022

    cat > "$_STATUS_FILE" <<EOF
{
