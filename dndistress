    timer_period_seconds() {

        if [ -n "${_TIMER_PERIOD:-}" ]; then
            p="$(parse_duration "$_TIMER_PERIOD" 2>/dev/null || true)"

            case "$p" in
                ''|*[!0-9]*|0)
                    return 1
                    ;;
            esac

            printf '%s\n' "$p"
            return 0
        fi

        if need_cmd systemctl; then
            raw="$(systemctl show "${UNIT_BASE}.timer" -p OnUnitActiveUSec --value 2>/dev/null || true)"
            raw="$(printf '%s\n' "$raw" | awk '{ sub(/^[[:space:]]+/, ""); sub(/[[:space:]]+$/, ""); print }')"

            case "$raw" in
                ''|0)
                    ;;
                *[!0-9]*)
                    sec="$(parse_duration "$raw" 2>/dev/null || true)"

                    case "$sec" in
                        ''|*[!0-9]*|0)
                            ;;
                        *)
                            printf '%s\n' "$sec"
                            return 0
                            ;;
                    esac

                    ;;
                *)
                    sec=$(( (raw + 999999) / 1000000 ))

                    [ "$sec" -gt 0 ] || return 1

                    printf '%s\n' "$sec"
                    return 0
                    ;;
            esac

        fi

        timer_file="$SERVICE_DIR/${UNIT_BASE}.timer"

        if [ -r "$timer_file" ]; then
            raw="$(awk -F= '
                /^[[:space:]]*OnUnitActiveSec[[:space:]]*=/ {
                    v=$2
                    sub(/^[[:space:]]+/, "", v)
                    sub(/[[:space:]]+$/, "", v)
                    print v
                    exit
                }
            ' "$timer_file")"

            [ -n "$raw" ] || return 1

            sec="$(parse_duration "$raw" 2>/dev/null || true)"

            case "$sec" in
                ''|*[!0-9]*|0)
                    return 1
                    ;;
            esac

            printf '%s\n' "$sec"
            return 0
        fi

        return 1
    }

    enforce_timer_duration_guard() {

