is_posint "$_QPS" || { log 1 "invalid _QPS=$_QPS"; exit 2; }
is_nonnegint "$_COLUMN" || { log 1 "invalid _COLUMN=$_COLUMN"; exit 2; }
is_nonnegint "$_COLUMN" || { log 1 "invalid _COLUMN=$_COLUMN"; exit 2; }
