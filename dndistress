}

compute_runtime_metrics() {
    sent="${SENT:-0}"
    start_ms="${START_TS:-$SCRIPT_START}"
    end_ms="${END_MS:-$(now_ms)}"
    last_sent_ms="${LAST_SENT_MS:-$start_ms}"
    queries_start="${QUERIES_START:-$start_ms}"

    if [ "$sent" -eq 0 ]; then
        last_sent_ms="$start_ms"
        queries_start="$start_ms"
    fi

    if [ "$sent" -gt 0 ] && [ "$last_sent_ms" -eq "$queries_start" ]; then
        last_sent_ms="$end_ms"
    fi

    active_ms=$((last_sent_ms - queries_start))
    queries_window_ms=$((last_sent_ms - queries_start))
    script_window_ms=$((end_ms - SCRIPT_START))

    if [ "$active_ms" -gt 0 ]; then
        ach_qps="$(awk -v s="$sent" -v ms="$active_ms" 'BEGIN { printf "%.2f", s / (ms / 1000) }')"
    else
        ach_qps="0"
    fi

    if [ "$script_window_ms" -gt 0 ]; then
        total_qps="$(awk -v s="$sent" -v ms="$script_window_ms" 'BEGIN { printf "%.2f", s / (ms / 1000) }')"
    else
        total_qps="0"
    fi

    BLOCKED=0
    BLOCK_PCT=0
    NXDOMAIN=0
    NXDOMAIN_PCT=0

    if [ -f "$ANSWERS_FILE" ]; then
        BLOCKED=$(awk '$0=="0.0.0.0" || $0=="::"' "$ANSWERS_FILE" | wc -l)
        NXDOMAIN=$(awk '$0=="NXDOMAIN"' "$ANSWERS_FILE" | wc -l)
        TOTAL=$(wc -l < "$ANSWERS_FILE")
        if [ "$TOTAL" -gt 0 ]; then
            BLOCK_PCT=$(awk -v b="$BLOCKED" -v t="$TOTAL" 'BEGIN{printf "%.0f", (b/t)*100}')
            NXDOMAIN_PCT=$(awk -v n="$NXDOMAIN" -v t="$TOTAL" 'BEGIN{printf "%.0f", (n/t)*100}')
        fi
    fi
}

