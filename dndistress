epoch_s_posix() {
    TZ=UTC0 date '+%Y %m %d %H %M %S' | awk '
        function leap(y) { return ((y%4==0 && y%100!=0) || (y%400==0)) }
        BEGIN {
            md[1]=31; md[2]=28; md[3]=31; md[4]=30; md[5]=31; md[6]=30
            md[7]=31; md[8]=31; md[9]=30; md[10]=31; md[11]=30; md[12]=31
        }
        {
            y=$1+0; m=$2+0; d=$3+0; H=$4+0; M=$5+0; S=$6+0
            days=0

            for (yy=1970; yy<y; yy++) days += leap(yy)?366:365

            for (mm=1; mm<m; mm++) {
                days += md[mm]

                if (mm==2 && leap(y)) days++

            }

            days += (d-1)
            print (days*86400 + H*3600 + M*60 + S)
        }'
}

now_ms() {
    t="$(date +%s%3N 2>/dev/null || true)"

    case "$t" in
        ''|*[!0-9]*)
            ;;
        *)
            printf '%s\n' "$t"
            return 0
            ;;
    esac

    t="$(date +%s 2>/dev/null || true)"

    case "$t" in
        ''|*[!0-9]*)
            ;;
        *)
            printf '%s000\n' "$t"
            return 0
            ;;
    esac

    t="$(epoch_s_posix)"
    printf '%s000\n' "$t"
}

make_tmpdir() {
    base="${1:-${TMPDIR:-/tmp}}"

    if need_cmd mktemp; then
        d="$(mktemp -d "$base/dns-prime-tokenbucket.XXXXXX" 2>/dev/null || true)"

        if [ -n "$d" ] && [ -d "$d" ]; then
            printf '%s\n' "$d"
            return 0
        fi

    fi

    umask 077
    i=0

    while [ "$i" -lt 1000 ]; do
        d="$base/dns-prime-tokenbucket.$$.$i"

        if mkdir "$d" 2>/dev/null; then
            printf '%s\n' "$d"
            return 0
        fi

        i=$((i + 1))
    done

    return 1
}

