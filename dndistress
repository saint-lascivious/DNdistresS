make_tmpdir() {
    base="${1:-${TMPDIR:-/tmp}}"

    if need_cmd mktemp; then
        d="$(mktemp -d "$base/dndistress.XXXXXX" 2>/dev/null || true)"

        if [ -n "$d" ] && [ -d "$d" ]; then
            printf '%s\n' "$d"
            return 0
        fi

    fi

    umask 077
    i=0

    while [ "$i" -lt 1000 ]; do
        d="$base/dndistress.$$.$i"

        if mkdir "$d" 2>/dev/null; then
            printf '%s\n' "$d"
            return 0
        fi

        i=$((i + 1))
    done

    return 1
}

RANDOM_RR_POOL="A AAAA CNAME MX NS TXT"
RANDOM_POOL_COUNT=0
RAND_STATE=1
PICKED_QTYPE="$_TYPE"

init_random_rr_pool() {
    old_ifs=$IFS
    IFS=' '
    # shellcheck disable=SC2086
    set -- $RANDOM_RR_POOL
    IFS=$old_ifs
    RANDOM_POOL_COUNT=$#

    [ "$RANDOM_POOL_COUNT" -gt 0 ] || RANDOM_POOL_COUNT=1

    seed="$(now_ms)"

    case "$seed" in
        ''|*[!0-9]*)
            seed=1
            ;;
    esac

    RAND_STATE=$(( (seed + $$) % 2147483647 ))

    [ "$RAND_STATE" -gt 0 ] || RAND_STATE=1

}

pick_query_type() {

    if [ "${_RANDOM:-0}" -ne 1 ]; then
        PICKED_QTYPE="$_TYPE"
        return 0
    fi

    [ "$RANDOM_POOL_COUNT" -gt 0 ] || init_random_rr_pool

    RAND_STATE=$(( (RAND_STATE * 1103515245 + 12345) % 2147483647 ))
    idx=$(( (RAND_STATE % RANDOM_POOL_COUNT) + 1 ))

    i=1
    for t in $RANDOM_RR_POOL; do

        if [ "$i" -eq "$idx" ]; then
            PICKED_QTYPE="$t"
            return 0
        fi

        i=$((i + 1))
    done

    PICKED_QTYPE="$_TYPE"

}

query_one() {
    d="$1"
    qtype="${2:-$_TYPE}"

    log 5 "${GREY}query_one: ${L_GREY}$d ${GREY}type=${L_GREY}$qtype${N_C}"

    case "$_BINARY" in
        dig)

            if [ "$_OUTPUT" = "answer" ]; then

                dig @"$RESOLVER" -p "$_PORT" "$d" "$qtype" +short +time=1 +tries=1 +retry=0 +notcp +ignore 2>/dev/null | \
                    tee -a "$ANSWERS_FILE" | \
                    awk -v GREY="$GREY" -v N_C="$N_C" 'NF { print "   " GREY "•" N_C " " $0 }'
            else

                dig @"$RESOLVER" -p "$_PORT" "$d" "$qtype" +short +time=1 +tries=1 +retry=0 +notcp +ignore 2>/dev/null >> "$ANSWERS_FILE"

            fi

            ;;
        nslookup)

            if [ "$_OUTPUT" = "answer" ]; then

                nslookup -port="$_PORT" -type="$qtype" "$d" "$RESOLVER" 2>/dev/null | \
                    awk '
                        /^Name:/ { seen=1; next }
                        seen && /^Address: /   { sub(/^Address: /,""); print $0 }
                        seen && /^Addresses: / { sub(/^Addresses: /,""); print $0 }
                    ' | tee -a "$ANSWERS_FILE" | \
                    awk -v GREY="$GREY" -v N_C="$N_C" 'NF { print "   " GREY "•" N_C " " $0 }'

            else

                nslookup -port="$_PORT" -type="$qtype" "$d" "$RESOLVER" 2>/dev/null | \
                    awk '
                        /^Name:/ { seen=1; next }
                        seen && /^Address: /   { sub(/^Address: /,""); print $0 }
                        seen && /^Addresses: / { sub(/^Addresses: /,""); print $0 }
                    ' >> "$ANSWERS_FILE"

            fi

            ;;
    esac

}

WORKER_PIDS=""
WORKER_FIFOS=""
WORKER_COUNT=0
WORKER_NEXT=0
WORKER_STOP_TOKEN="__DNDISTRESS_STOP__"

enqueue_job() {
    payload="$1"
    [ "$WORKER_COUNT" -gt 0 ] || return 1

    idx=$(( (WORKER_NEXT % WORKER_COUNT) + 1 ))
    WORKER_NEXT=$((WORKER_NEXT + 1))

    i=1
    target_fifo=""

    for f in $WORKER_FIFOS; do

        if [ "$i" -eq "$idx" ]; then
            target_fifo="$f"
            break
        fi

        i=$((i + 1))
    done

    [ -n "$target_fifo" ] || return 1

    printf '%s\n' "$payload" > "$target_fifo"
}

start_worker_pool() {
    workers="$1"

    WORKER_COUNT="$workers"
    WORKER_NEXT=0
    WORKER_FIFOS=""
    WORKER_PIDS=""

    log 5 "${GREY}start_worker_pool: workers=${L_GREY}$workers${N_C}"

    i=0
    while [ "$i" -lt "$workers" ]; do
        fifo="$TMPDIR/queue.$i.fifo"

        rm -f "$fifo"

        mkfifo "$fifo" || {

            log 0 "${BOLD}${RED}failed to create worker fifo: ${L_GREY}$fifo${N_C}"

            return 1
        }

        (
            while :; do
                IFS= read -r job < "$fifo" || continue

                [ -n "$job" ] || continue

                [ "$job" = "$WORKER_STOP_TOKEN" ] && break

                case "$job" in
                    *'|'*)
                        qtype=${job%%|*}
                        d=${job#*|}
                        ;;
                    *)
                        qtype="$_TYPE"
                        d="$job"
                        ;;
                esac

                [ -n "$d" ] || continue

                query_one "$d" "$qtype"

            done

        ) &

        WORKER_PIDS="$WORKER_PIDS $!"
        WORKER_FIFOS="$WORKER_FIFOS $fifo"

        log 5 "${GREY}start_worker_pool: started worker pid=${L_GREY}$! ${GREY}fifo=${L_GREY}$fifo${N_C}"

        i=$((i + 1))
    done

    return 0
}

