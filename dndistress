is_absolute_path() {

    case "$1" in
        /*) return 0 ;;
        *)  return 1 ;;
    esac

}

is_valid_target_dir() {
    p="$1"
    is_absolute_path "$p" || return 1

    [ -e "$p" ] && [ ! -d "$p" ] && return 1

    return 0
}

self_source_path() {

    if [ -f "$0" ]; then
        printf '%s\n' "$0"
        return 0
    fi

    p="$(command -v "$0" 2>/dev/null || true)"

    if [ -n "$p" ] && [ -f "$p" ]; then
        printf '%s\n' "$p"
        return 0
    fi

    return 1
}

as_root_or_sudo() {

    [ "$(id -u)" -eq 0 ] && return 0

    if need_cmd sudo; then
        exec sudo "$0" "$@"
    fi

    log 1 "root privileges required; sudo unavailable"
    return 1
}

systemctl_maybe() {

    if need_cmd systemctl; then
        systemctl "$@" >/dev/null 2>&1 || true
    fi

}

write_service_unit() {
    out="$1"
    exec_path="$2"

    cat > "$out" <<EOF
[Unit]
Description=Run DNdistresS DNS query workload
Documentation=man:systemd.service(5)
Wants=network-online.target
After=network-online.target
ConditionPathIsExecutable=$exec_path

[Service]
Type=oneshot
User=root
Group=root
UMask=0027
Environment=_DIRECTORY=/var/cache/dndistress
Environment=_VERBOSITY=3
ExecStart=$exec_path
StandardOutput=journal
StandardError=journal
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/cache/dndistress

[Install]
WantedBy=multi-user.target
EOF
}

write_timer_unit() {
    out="$1"

    cat > "$out" <<EOF
[Unit]
Description=Periodic DNdistresS run
Documentation=man:systemd.timer(5)

[Timer]
OnBootSec=2min
OnUnitActiveSec=1h
Persistent=true
RandomizedDelaySec=5min
AccuracySec=1min
Unit=dndistress.service

[Install]
WantedBy=timers.target
EOF
}

do_install() {
    target="$1"
    is_valid_target_dir "$target" || { log 1 "invalid install path: $target"; exit 2; }

    as_root_or_sudo -i "$target"

    mkdir -p "$target"
    src="$(self_source_path)" || { log 1 "unable to resolve script path"; exit 1; }

    if need_cmd install; then
        install -m 0755 "$src" "$target/$UNIT_BASE"
        log 4 "installed using 'install' command"
    else
        cp "$src" "$target/$UNIT_BASE"
        chmod 0755 "$target/$UNIT_BASE"
        log 4 "installed using 'cp' and 'chmod'"
    fi

    mkdir -p "$SERVICE_DIR"
    log 4 "ensured service directory exists: $SERVICE_DIR"

    write_service_unit "$SERVICE_DIR/${UNIT_BASE}.service" "$target/$UNIT_BASE"
    log 4 "wrote service unit to $SERVICE_DIR/${UNIT_BASE}.service"

    write_timer_unit "$SERVICE_DIR/${UNIT_BASE}.timer"
    log 4 "wrote timer unit to $SERVICE_DIR/${UNIT_BASE}.timer"

    systemctl_maybe daemon-reload
    log 4 "reloaded systemd daemon"
    systemctl_maybe enable --now "${UNIT_BASE}.timer"
    log 4 "enabled and started timer unit ${UNIT_BASE}.timer"

    log 3 "installed: $target/$UNIT_BASE"
    log 3 "installed: $SERVICE_DIR/${UNIT_BASE}.service"
    log 3 "installed: $SERVICE_DIR/${UNIT_BASE}.timer"
}

do_uninstall() {
    target="$1"
    is_valid_target_dir "$target" || { log 1 "invalid uninstall path: $target"; exit 2; }

    as_root_or_sudo -u "$target"

    systemctl_maybe disable --now "${UNIT_BASE}.timer"
    systemctl_maybe stop "${UNIT_BASE}.service"
    log 4 "disabled timer unit ${UNIT_BASE}.timer and stopped service unit ${UNIT_BASE}.service"

    rm -f "$SERVICE_DIR/${UNIT_BASE}.service" "$SERVICE_DIR/${UNIT_BASE}.timer" || true
    rm -f "$target/$UNIT_BASE" || true
    log 4 "removed files for $UNIT_BASE from $target and $SERVICE_DIR"

    systemctl_maybe daemon-reload
    log 4 "reloaded systemd daemon"

    log 3 "removed units and binary for $UNIT_BASE"
}

download_file() {
    src="$1"
    dst="$2"

    if need_cmd curl; then
        log 4 "downloading using curl: $src -> $dst"
        curl -fsSL "$src" -o "$dst"
    elif need_cmd wget; then
        log 4 "downloading using wget: $src -> $dst"
        wget -qO "$dst" "$src"
    else
        log 1 "need curl or wget for downloading"
        return 1
    fi

}

cache_key() {
    printf '%s\n' "$1" | cksum | awk '{ print $1 }'
    log 4 "cache_key: input='$1' key='$(printf '%s\n' "$1" | cksum | awk '{ print $1 }')'"
}

copy_if_needed() {
    src="$1"
    dst="$2"

    [ "$src" = "$dst" ] && return 0

    cp "$src" "$dst"
}

CACHE_AGE=0
USING_CACHE=0
USING_CACHE_STR=""

fetch_source() {
    dst="$1"

    if [ -n "$_FILE" ]; then
        log 3 "using local source: $_FILE"
        log 4 "fetch_source: copy local file to '$dst'"
        copy_if_needed "$_FILE" "$dst"
        return 0
    fi

    if [ "$_SECONDS" -eq 0 ]; then
        log 3 "Downloading: $_URL"
        log 4 "fetch_source: cache disabled (_SECONDS=0)"
        download_file "$_URL" "$dst"
        return 0
    fi

    mkdir -p "$_DIRECTORY"

    key="$(cache_key "$_URL")"
    cache_raw="$_DIRECTORY/$key.raw"
    cache_stamp="$_DIRECTORY/$key.stamp"
    now="$(( $(now_ms) / 1000 ))"
    log 4 "fetch_source: key=$key cache_raw='$cache_raw' cache_stamp='$cache_stamp' now=$now"

    if [ -f "$cache_raw" ] && [ -f "$cache_stamp" ]; then
        cached_at="$(cat "$cache_stamp" 2>/dev/null || printf '0')"

        case "$cached_at" in
            ''|*[!0-9]*)
                cached_at=0
                ;;
        esac

        CACHE_AGE=$((now - cached_at))
        log 4 "fetch_source: cache candidate age=$CACHE_AGE ttl=$_SECONDS"

        if [ "$CACHE_AGE" -lt "$_SECONDS" ]; then
            USING_CACHE="1"
            log 4 "fetch_source: cache hit"
            copy_if_needed "$cache_raw" "$dst"
            return 0
        fi

        log 4 "fetch_source: cache stale"

    fi

    log 3 "Downloading: $_URL"
    log 4 "fetch_source: downloading fresh copy"
    download_file "$_URL" "$cache_raw"
    printf '%s\n' "$now" > "$cache_stamp"
    copy_if_needed "$cache_raw" "$dst"
}

extract_domains() {
    awk -F',' -v fmt="$_FORMAT" -v col="$_COLUMN" '
        function norm(x) {
            gsub(/\r/, "", x)
            sub(/^[[:space:]]+/, "", x)
            sub(/[[:space:]]+$/, "", x)
            x=tolower(x)
            sub(/\.$/, "", x)
            return x
        }

        function is_domain(x) {
            return (x ~ /^[a-z0-9][a-z0-9.-]*[a-z0-9]$/)
        }

        {
            d=""

            if (fmt == "plain") {
                d=norm($0)

                if (is_domain(d)) print d

                next
            }

            if (col > 0) {

                if (col <= NF) {
                    d=norm($col)

                    if (is_domain(d)) print d

                }

                next
            }

            if (NF == 1) {
                d=norm($1)

                if (is_domain(d)) {
                    print d
                    next
                }

            }

            if ($1 ~ /^[0-9]+$/ && NF >= 2) {
                d=norm($2)

                if (is_domain(d)) {
                    print d
                    next
                }

            }

            for (i=1; i<=NF; i++) {
                d=norm($i)

                if (is_domain(d) && d !~ /^[0-9]+$/) {
                    print d
                    break
                }

            }

        }
    '
}

extract_custom_domains() {
    awk '
        function norm(x) {
            gsub(/\r/, "", x)
            sub(/[[:space:]]*#.*$/, "", x)
            sub(/^[[:space:]]+/, "", x)
            sub(/[[:space:]]+$/, "", x)
            x=tolower(x)
            sub(/\.$/, "", x)
            return x
        }

        function is_domain(x) {
            return (x ~ /^[a-z0-9][a-z0-9.-]*[a-z0-9]$/)
        }

        {
            d=norm($0)

            if (d == "") next

            if (is_domain(d)) print d

        }
    '
}

choose_tool() {

    case "$_BINARY" in
        auto)

            if need_cmd dig; then
                _BINARY="dig"
            elif need_cmd nslookup; then
                _BINARY="nslookup"
            else
                log 1 "need dig or nslookup for querying"
                return 1
            fi

            ;;
        dig)
            need_cmd dig || { log 1 "dig not found"; return 1; }
            ;;
        nslookup)
            need_cmd nslookup || { log 1 "nslookup not found"; return 1; }
            ;;
        *)
            log 1 "_BINARY must be one (1) of auto|dig|nslookup, got: $_BINARY"
            return 1
            ;;
    esac

    log 4 "choose_tool: using '$_BINARY' for DNS queries"
}

query_one() {
    d="$1"

    case "$_BINARY" in
        dig)

            if [ "$_OUTPUT" = "answer" ]; then
                dig @"$RESOLVER" -p "$_PORT" "$d" "$_TYPE" +short +time=1 +tries=1 +retry=0 +notcp +ignore 2>/dev/null | awk 'NF'
            else
                dig @"$RESOLVER" -p "$_PORT" "$d" "$_TYPE" +short +time=1 +tries=1 +retry=0 +notcp +ignore >/dev/null 2>&1 || true
            fi

            ;;
        nslookup)

            if [ "$_OUTPUT" = "answer" ]; then
                nslookup -port="$_PORT" -type="$_TYPE" "$d" "$RESOLVER" 2>/dev/null | awk '
                    /^Name:/ { seen=1; next }
                    seen && /^Address: /   { sub(/^Address: /,""); print }
                    seen && /^Addresses: / { sub(/^Addresses: /,""); print }
                '
            else
                nslookup -port="$_PORT" -type="$_TYPE" "$d" "$RESOLVER" >/dev/null 2>&1 || true
            fi

            ;;
    esac

}

WORKER_PIDS=""
QUEUE_FIFO=""
WRITER_FD_OPEN=0

start_worker_pool() {
    workers="$1"
    QUEUE_FIFO="$TMPDIR/queue.fifo"

    rm -f "$QUEUE_FIFO"
    mkfifo "$QUEUE_FIFO" || { log 1 "failed to create queue fifo: $QUEUE_FIFO"; return 1; }
    log 4 "start_worker_pool: workers=$workers fifo='$QUEUE_FIFO'"

    i=0
    while [ "$i" -lt "$workers" ]; do
        (
            while IFS= read -r d; do

                [ -n "$d" ] || continue

                query_one "$d"
            done < "$QUEUE_FIFO"

        ) &
        WORKER_PIDS="$WORKER_PIDS $!"
        log 4 "start_worker_pool: started worker pid=$!"
        i=$((i + 1))
    done

    exec 4> "$QUEUE_FIFO"
    WRITER_FD_OPEN=1
    return 0
}

