fmt_one_of() {
    out=""

    for v in "$@"; do
        [ -n "$out" ] && out="${out}${RED}|"
        out="${out}${L_GREY}${v}"
    done

    printf '%s\n' "$out"
}

log_invalid_enum() {
    name="$1"
