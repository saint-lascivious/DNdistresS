    dst="$2"

    if need_cmd curl; then

        log 5 "${GREY}downloading using curl: ${L_GREY}$src ${GREY}-> ${L_GREY}$dst${N_C}"

        curl -fsSL "$src" -o "$dst" || {

            log 1 "${RED}download failed with curl: ${L_GREY}$src${N_C}"

            return 1
        }

    elif need_cmd wget; then

        log 4 "${GREY}downloading using wget: ${L_GREY}$src ${GREY}-> ${L_GREY}$dst${N_C}"

        wget -qO "$dst" "$src" || {

            log 1 "${RED}download failed with wget: ${L_GREY}$src${N_C}"

            return 1
        }

    else

        log 1 "${RED}need curl or wget for downloading${N_C}"

        return 1
    fi

}

validate_zip_file() {
