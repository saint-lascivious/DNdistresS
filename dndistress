    exit 2
}
_SECONDS_RAW="$_SECONDS"
_SECONDS="$(parse_duration "$_SECONDS_RAW")" || {
    log 1 "invalid _SECONDS='$_SECONDS_RAW' (use seconds or e.g. 1h, 2d 14h 27m 52s)"
    exit 2
}

enforce_timer_duration_guard

if [ "$_MAXIMUM" -gt 128 ]; then
    log 2 "_MAXIMUM too high ($_MAXIMUM), clamping to 128"
    _MAXIMUM=128
fi

max_burst=$((_QPS * 2))

if [ "$_BURST" -gt "$max_burst" ]; then
    log 2 "_BURST too high for _QPS ($_BURST > $max_burst), clamping"
    _BURST="$max_burst"
fi

case "$_FORMAT" in
    auto|plain|csv)
        ;;
    *)
        log 1 "_FORMAT must be one (1) of auto|plain|csv, got: $_FORMAT"
        exit 2
        ;;
esac

case "$_OUTPUT" in
    quiet|answer)
        ;;
    *)
        log 1 "_OUTPUT must be one (1) of quiet|answer, got: $_OUTPUT"
        exit 2
        ;;
esac

_TYPE="$(printf '%s' "$_TYPE" | tr '[:lower:]' '[:upper:]')"
_TYPE_ID=""

case "$_TYPE" in
    ANY)
        log 1 "_TYPE=ANY is not allowed"
        exit 2
        ;;
    TYPE[0-9]*)
        _TYPE_ID="${_TYPE#TYPE}"
        ;;
    [0-9]*)
        _TYPE_ID="$_TYPE"
        ;;
esac

if [ -n "$_TYPE_ID" ]; then

    case "$_TYPE_ID" in
        ''|*[!0-9]*)
            log 1 "invalid _TYPE=$_TYPE"
            exit 2
            ;;
    esac

    [ "$_TYPE_ID" -ge 1 ] && [ "$_TYPE_ID" -le 65535 ] || {
        log 1 "_TYPE RR ID must be one (1) of 1|...|65535, got: $_TYPE_ID"
        exit 2
    }

    [ "$_TYPE_ID" -ne 255 ] || {
        log 1 "_TYPE RR ID 255 (ANY) is not allowed"
        exit 2
    }

    _TYPE_MN="$(rr_type_from_id "$_TYPE_ID" 2>/dev/null || true)"

    [ -n "$_TYPE_MN" ] || {
