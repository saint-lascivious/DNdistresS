is_ipv4_addr() {
    ip="$1"

    IFS=. read -r o1 o2 o3 o4 extra <<EOF
$ip
EOF

    [ -z "${extra:-}" ] || return 1

    for oct in "$o1" "$o2" "$o3" "$o4"; do

        case "$oct" in
            ''|*[!0-9]*)
                return 1
                ;;
        esac

        [ "$oct" -le 255 ] || return 1

    done

    return 0
}

is_local_ipv4() {
    ip="$1"

    is_ipv4_addr "$ip" || return 1

    IFS=. read -r o1 o2 o3 o4 extra <<EOF
$ip
EOF

    [ -z "${extra:-}" ] || return 1

    [ "$o1" -eq 127 ] && return 0

    [ "$o1" -eq 10 ] && return 0

    [ "$o1" -eq 192 ] && [ "$o2" -eq 168 ] && return 0

    [ "$o1" -eq 172 ] && [ "$o2" -ge 16 ] && [ "$o2" -le 31 ] && return 0

    [ "$o1" -eq 169 ] && [ "$o2" -eq 254 ] && return 0

    return 1
}

is_ipv6_addr_basic() {
    ip="$1"
    addr="$ip"
    zone=""

    case "$addr" in
        *%*)
            zone=${addr#*%}
            addr=${addr%%\%*}

            is_zone_id "$zone" || return 1

            ;;
    esac

    [ -n "$addr" ] || return 1

    printf '%s\n' "$addr" | awk '
        function is_h16(x) {
            return (x ~ /^[0-9A-Fa-f]{1,4}$/)
        }

        function is_ipv4(x, o, i) {

            if (x !~ /^([0-9]{1,3}\.){3}[0-9]{1,3}$/) return 0

            split(x, o, ".")

            for (i=1; i<=4; i++) {

                if (o[i] < 0 || o[i] > 255) return 0

            }

            return 1
        }

        BEGIN { ok=1 }

        {
            s=$0

            if (s == "") ok=0

            if (s ~ /:::/) ok=0

            if (ok && index(s, ".")) {
                n=split(s, p, ":")
                tail=p[n]

                if (!is_ipv4(tail)) ok=0

                if (ok) s=substr(s, 1, length(s)-length(tail)) "0:0"

            }

            if (ok && s !~ /^[0-9A-Fa-f:]+$/) ok=0

            t=s
            dc=gsub(/::/, "@", t)

            if (dc > 1) ok=0

            if (ok && dc == 0) {
                n=split(s, a, ":")

                if (n != 8) ok=0

                if (ok) {

                    for (i=1; i<=n; i++) {

                        if (!is_h16(a[i])) {
                            ok=0
                            break
                        }

                    }

                }

            }

            if (ok && dc == 1) {

                n2=split(t, lr, "@")

                if (n2 != 2) ok=0

                left=lr[1]
                right=lr[2]
                lcnt=0
                rcnt=0

                if (ok && left != "") {

                    nl=split(left, la, ":")
                    lcnt=nl

                    for (i=1; i<=nl; i++) {

                        if (!is_h16(la[i])) {
                            ok=0
                            break
                        }

                    }

                }

                if (ok && right != "") {
                    nr=split(right, ra, ":")
                    rcnt=nr

                    for (i=1; i<=nr; i++) {

                        if (!is_h16(ra[i])) {
                            ok=0
                            break
                        }

                    }

                }

                if (ok && (lcnt + rcnt) >= 8) ok=0

            }

        }

        END { exit(ok ? 0 : 1) }
    '
}

is_local_ipv6() {
    ip_lc="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"

    is_ipv6_addr_basic "$ip_lc" || return 1

    addr="$ip_lc"

    case "$addr" in
        *%*)
            addr=${addr%%\%*}

            case "$addr" in
                fe8*:*|fe9*:*|fea*:*|feb*:*)
                    ;;
                *)
                    return 1
                    ;;
            esac

            ;;
    esac

    case "$addr" in
        *.*)
            v4tail=${addr##*:}

            is_ipv4_addr "$v4tail" || return 1

            is_local_ipv4 "$v4tail" && return 0

            return 1
            ;;
    esac

    case "$addr" in
        ::1|fc*:*|fd*:*|fe8*:*|fe9*:*|fea*:*|feb*:*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac

}

is_valid_local_dns() {
    ip="$1"

    is_local_ipv4 "$ip" && return 0

    is_local_ipv6 "$ip" && return 0

    return 1
}

is_valid_dns() {
    ip="$1"

    case "$ip" in
        *%*)
            return 1
            ;;
    esac

    is_ipv4_addr "$ip" && return 0

    is_ipv6_addr_basic "$ip" && return 0

    return 1
}

PARSED_DNS_HOST=""
PARSED_DNS_PORT=""

parse_dns_opt() {
    arg="$1"
    host=""
    prt=""

    case "$arg" in
        *\#*)
            host=${arg%\#*}
            prt=${arg##*\#}
            ;;
        \[*\]:*)
            t=${arg#\[}
            host=${t%%\]*}
            t=${t#*\]}
            prt=${t#:}
            ;;
        \[*\])
            t=${arg#\[}
            host=${t%\]}
            ;;
        *:*)
            t=${arg#*:}

            if [ "${t#*:}" = "$t" ]; then
                host=${arg%:*}
                prt=${arg##*:}
            else
                host=$arg
            fi

            ;;
        *)
            host=$arg
            ;;
    esac

    case "$host" in
        \[*\])
            host=${host#\[}
            host=${host%\]}
            ;;
    esac

    [ -n "$host" ] || return 1

    if [ -n "$prt" ]; then

        is_port "$prt" || return 1

    fi

    PARSED_DNS_HOST="$host"
    PARSED_DNS_PORT="$prt"

    log 5 "${GREY}parse_dns_opt: parsed host='${L_GREY}${host}${GREY}' port='${L_GREY}${prt}${GREY}' from arg='${L_GREY}${arg}${GREY}'${N_C}"

    return 0
}

format_runtime_ms() {
    ms="${1:-0}"

    case "$ms" in
        ''|*[!0-9]*)
            ms=0
            ;;
    esac

    if [ "$ms" -lt 1000 ]; then
        printf '%dms\n' "$ms"
        return 0
    fi

    rem_ms=$((ms % 1000))
    frac=""

    if [ "$rem_ms" -gt 0 ]; then
        frac=" ${rem_ms}ms"
    fi

    total_s=$((ms / 1000))

    if [ "$total_s" -lt 60 ]; then
        printf '%ds%s\n' "$total_s" "$frac"
        return 0
    fi

    s=$((total_s % 60))
    total_m=$((total_s / 60))

    if [ "$total_m" -lt 60 ]; then
        printf '%dm %ds%s\n' "$total_m" "$s" "$frac"
        return 0
    fi

    m=$((total_m % 60))
    total_h=$((total_m / 60))

    if [ "$total_h" -lt 24 ]; then
        printf '%dh %dm %ds%s\n' "$total_h" "$m" "$s" "$frac"
        return 0
    fi

    h=$((total_h % 24))
    total_d=$((total_h / 24))

    if [ "$total_d" -lt 7 ]; then
        printf '%dd %dh %dm %ds%s\n' "$total_d" "$h" "$m" "$s" "$frac"
        return 0
    fi

    if [ "$total_d" -lt 30 ]; then
        w=$((total_d / 7))
        d=$((total_d % 7))
        printf '%dw %dd %dh %dm %ds%s\n' "$w" "$d" "$h" "$m" "$s" "$frac"
        return 0
    fi

    if [ "$total_d" -lt 365 ]; then
        mo=$((total_d / 30))
        rem_d=$((total_d % 30))
        w=$((rem_d / 7))
        d=$((rem_d % 7))
        printf '%dmo %dw %dd %dh %dm %ds%s\n' "$mo" "$w" "$d" "$h" "$m" "$s" "$frac"
        return 0
    fi

    y=$((total_d / 365))
    rem_y_d=$((total_d % 365))
    mo=$((rem_y_d / 30))
    rem_d=$((rem_y_d % 30))
    w=$((rem_d / 7))
    d=$((rem_d % 7))
    printf '%dy %dmo %dw %dd %dh %dm %ds%s\n' "$y" "$mo" "$w" "$d" "$h" "$m" "$s" "$frac"
}

