collect_script_metrics() {
    UNKNOWN_METRIC="unknown (something went wrong)"

    awk '
        BEGIN {
            in_fn=0; fn_depth=0; fn_nesting=0
            max_fn_nesting=0; max_brace_depth=0; max_subshell_depth=0
            in_awk=0; awk_block_len=0; max_awk_block=0
        }

        function brace_delta(s, t, o, c) {
            t=s; o=gsub(/\{/, "{", t)
            t=s; c=gsub(/\}/, "}", t)
            return (o-c)
        }

        {
            line=$0

            if (line ~ /^[[:space:]]*[A-Za-z_][A-Za-z0-9_]*[[:space:]]*\(\)[[:space:]]*\{[[:space:]]*$/) {
                fn_nesting++
                if (fn_nesting > max_fn_nesting) max_fn_nesting=fn_nesting
            }

            if (line ~ /^[[:space:]]*\}[[:space:]]*$/ && fn_nesting > 0) {
                fn_nesting--
            }

            if (!in_fn) {
                if (line ~ /^[[:space:]]*[A-Za-z_][A-Za-z0-9_]*[[:space:]]*\(\)[[:space:]]*\{[[:space:]]*$/) {
                    in_fn=1
                    fn_count++
                    cur_fn_len=1
                    fn_depth=brace_delta(line)

                    if (fn_depth <= 0) {
                        fn_total += cur_fn_len
                        if (cur_fn_len > fn_max) fn_max=cur_fn_len
                        in_fn=0; cur_fn_len=0; fn_depth=0
                    }

                }

            } else {
                cur_fn_len++
                fn_depth += brace_delta(line)

                if (fn_depth <= 0) {
                    fn_total += cur_fn_len
                    if (cur_fn_len > fn_max) fn_max=cur_fn_len
                    in_fn=0; cur_fn_len=0; fn_depth=0
                }
            }

            brace_depth += brace_delta(line)
            if (brace_depth > max_brace_depth) max_brace_depth=brace_depth

            tmp=line
            while (match(tmp, /\$\(|[^$]\(|\)/)) {
                tok=substr(tmp, RSTART, RLENGTH)
                if (tok == ")") subshell_depth--
                else subshell_depth++
                if (subshell_depth > max_subshell_depth) max_subshell_depth=subshell_depth
                if (subshell_depth < 0) subshell_depth=0
                tmp=substr(tmp, RSTART+RLENGTH)
            }

            if (!in_awk && $0 ~ /awk[[:space:]]*(["'"'"']|<<)/) {
                in_awk=1
                awk_block_len=1
            } else if (in_awk) {
                awk_block_len++
    
                if ($0 ~ /^(['"'"'"]|EOF|END)[[:space:]]*$/ || $0 ~ /'"'"'/ || $0 ~ /"/) {
                    if (awk_block_len > max_awk_block) max_awk_block=awk_block_len
                    in_awk=0
                    awk_block_len=0
                }

            }

            char_total += length(line)

            if (length(line) > max_line_len) max_line_len=length(line)

            if (line ~ /^[[:space:]]*$/) {
                blank++
                next
            }

            nonblank++

            is_shebang   = (NR == 1 && line ~ /^#!/)
            is_directive = (!is_shebang && line ~ /^[[:space:]]*#[[:space:]]*shellcheck([[:space:]]|$)/)
            is_comment   = (!is_shebang && !is_directive && line ~ /^[[:space:]]*#/)

            if (is_directive) directives++

            if (is_comment) comments++

            tmp=line

            while (match(tmp, /(^|[[:space:];(])(export[[:space:]]+|readonly[[:space:]]+|local[[:space:]]+|typeset[[:space:]]+)?[A-Za-z_][A-Za-z0-9_]*=/)) {
                seg=substr(tmp, RSTART, RLENGTH)
                sub(/.*[[:space:];(]/, "", seg)
                sub(/^(export|readonly|local|typeset)[[:space:]]+/, "", seg)
                sub(/=.*/, "", seg)
                if (seg ~ /^[A-Za-z_][A-Za-z0-9_]*$/) seen[seg]=1
                tmp=substr(tmp, RSTART+RLENGTH)
            }

            tmp=line

            while (match(tmp, /\$\{[A-Za-z_][A-Za-z0-9_]*/)) {
                v=substr(tmp, RSTART+2, RLENGTH-2)
                seen[v]=1
                tmp=substr(tmp, RSTART+RLENGTH)
            }

            tmp=line

            while (match(tmp, /\$[A-Za-z_][A-Za-z0-9_]*/)) {
                v=substr(tmp, RSTART+1, RLENGTH-1)
                seen[v]=1
                tmp=substr(tmp, RSTART+RLENGTH)
            }

            if (!is_comment && !is_directive) {
                if (line ~ /^[[:space:]]*if[[:space:]]/ || line ~ /^[[:space:]]*elif[[:space:]]/ || line ~ /^[[:space:]]*else[[:space:]]*$/) ifs++

                if (line ~ /^[[:space:]]*case[[:space:]].*[[:space:]]*in[[:space:]]*$/) case_count++

                tmp=line

                while (match(tmp, /;;/)) { arms++; tmp=substr(tmp, RSTART+RLENGTH) }

                if (line ~ /^[[:space:]]*for[[:space:]].*;[[:space:]]*do([[:space:]]*#.*)?$/)        loop_count++
                else if (line ~ /^[[:space:]]*while[[:space:]].*;[[:space:]]*do([[:space:]]*#.*)?$/) loop_count++

                tmp=line

                while (match(tmp, /\|[^|]/)) { pipes++; tmp=substr(tmp, RSTART+RLENGTH) }

                tmp=line

                while (match(tmp, /\$\(/)) { subshells++; tmp=substr(tmp, RSTART+RLENGTH) }

                tmp=line

                while (match(tmp, /<<[-]?[[:space:]]*/)) {
                    heredocs++
                    tmp=substr(tmp, RSTART+RLENGTH)
                }

                if (line ~ /^[[:space:]]*(\.|source)[[:space:]]+[A-Za-z0-9_\.\/-]+/) sourcing++

                if (line ~ /(^|[[:space:];])exit[[:space:]]*[0-9]*/) exits++

                if (line ~ /^[[:space:]]*trap[[:space:]]/) traps++

            }
        }

        END {
            vars=0
            for (k in seen) vars++
            total = nonblank + blank

            if (fn_count > 0) avg_fn = fn_total / fn_count
            else avg_fn = 0

            if (nonblank > 0) c_pct = (comments * 100.0) / nonblank
            else c_pct = 0

            if (case_count > 0) avg_arms = arms / case_count
            else avg_arms = 0

            if (nonblank > 0) total_loc_ratio = total / nonblank
            else total_loc_ratio = 0

            max_depth = (max_brace_depth > max_subshell_depth) ? max_brace_depth : max_subshell_depth

            printf "\
Functions:             %d\n\
Max function LOC:      %d\n\
Average function LOC:  %.2f\n\
Function nesting:      %d (maximum depth)\n\
Maximum depth:         %d (maximum brace/subshell nesting depth)\n\
Maximum awk block:     %d (lines in the largest awk block)\n\
\n\
Total:                 %d (all lines)\n\
LOC:                   %d (excludes whitespace)\n\
LOC ratio:             %.2f (%d/%d total/LOC)\n\
Blank:                 %d\n\
Characters:            %d\n\
Longest line:          %d\n\
\n\
Comments:              %d (excludes shebang + shellcheck directives)\n\
Shellcheck directives: %d\n\
Comment ratio:         %.2f%% (%d/%d regular comments/non-blank lines)\n\
\n\
Variables:             %d (unique shell-style variables seen)\n\
If/Elif/Else blocks:   %d\n\
Case statements:       %d\n\
Average case arms:     %.2f (;; per case statement)\n\
Loops:                 %d (strict for/while ...; do)\n\
Pipes:                 %d (| usage)\n\
Subshells:             %d (\\$(...) usage)\n\
Heredocs:              %d (<< usage)\n\
Sourcing:              %d (. or source)\n\
Traps:                 %d\n\
Exits:                 %d\n", \
fn_count+0, fn_max+0, avg_fn, max_fn_nesting+0, max_depth+0, \
max_awk_block+0, total+0, nonblank+0, total_loc_ratio, total+0, nonblank+0, \
blank+0, char_total+0, max_line_len+0, comments+0, directives+0, c_pct, \
comments+0, nonblank+0, vars+0, ifs+0, case_count+0, avg_arms, loop_count+0, \
pipes+0, subshells+0, heredocs+0, sourcing+0, traps+0, exits+0
        }
    ' "$0" 2>/dev/null || printf '%s\n' \
        "Functions:             $UNKNOWN_METRIC" \
        "Max function LOC:      $UNKNOWN_METRIC" \
        "Average function LOC:  $UNKNOWN_METRIC" \
        "Function nesting:      $UNKNOWN_METRIC" \
        "Maximum depth:         $UNKNOWN_METRIC" \
        "Maximum awk block:     $UNKNOWN_METRIC" \
        "" \
        "Total:                 $UNKNOWN_METRIC" \
        "LOC:                   $UNKNOWN_METRIC" \
        "LOC ratio:             $UNKNOWN_METRIC" \
        "Blank:                 $UNKNOWN_METRIC" \
        "Characters:            $UNKNOWN_METRIC" \
        "Longest line:          $UNKNOWN_METRIC" \
        "" \
        "Comments:              $UNKNOWN_METRIC" \
        "Shellcheck directives: $UNKNOWN_METRIC" \
        "Comment ratio:         $UNKNOWN_METRIC" \
        "" \
        "Variables:             $UNKNOWN_METRIC" \
        "If/Elif/Else blocks:   $UNKNOWN_METRIC" \
        "Case statements:       $UNKNOWN_METRIC" \
        "Average case arms:     $UNKNOWN_METRIC" \
        "Loops:                 $UNKNOWN_METRIC" \
        "Pipes:                 $UNKNOWN_METRIC" \
        "Subshells:             $UNKNOWN_METRIC" \
        "Heredocs:              $UNKNOWN_METRIC" \
        "Sourcing:              $UNKNOWN_METRIC" \
        "Traps:                 $UNKNOWN_METRIC" \
        "Exits:                 $UNKNOWN_METRIC"
}

usage() {

    [ "$_VERBOSITY" -ge 3 ] && print_banner

    prog_name="${0##*/}"

    awk -v prog="$prog_name" -v syn="$SYNOPSIS" -v cols="${COLUMNS:-80}" '
        BEGIN {
            print "Usage:"
            head = "  " prog " "
            ind  = sprintf("%" length(head) "s", "")
            line = head
            s    = syn
            while (length(s) > 0) {
                if (substr(s,1,1) != "[") break
                depth = 0
                tok = ""
                for (i = 1; i <= length(s); i++) {
                    c = substr(s, i, 1)
                    tok = tok c
                    if (c == "[") depth++
                    else if (c == "]") { depth--; if (depth == 0) break }
                }
                s = substr(s, length(tok) + 1)
                sub(/^[[:space:]]+/, "", s)
                cand = (line == head) ? line tok : line " " tok
                if (length(cand) + 2 > cols) {
                    printf "%s \\\n", line
                    line = ind tok
                } else {
                    line = cand
                }
            }
            print line
            print ""
            print "  " prog " --help [topic]"
            print "  " prog " help [topic]"
            print "  " prog " install [PATH]"
            print "  " prog " uninstall [PATH]"
            print "  " prog " show {w|c|warranty|conditions}"
            print "  " prog " --show {w|c|warranty|conditions}"
            print "  " prog " --show-warranty"
            print "  " prog " --show-conditions"
        }
    '

    cat <<EOF

Help:
  -h, --help [topic]

  help [topic]
      Show help for a specific topic. Topic can be a command or option.

      Reverse parsing is supported (examples):
        ${0##*/} --help --install
        ${0##*/} --install --help
        ${0##*/} --help -q
        ${0##*/} -q --help

Topic examples:
  install, uninstall, show, version, verbosity

Tip:
  Run '${0##*/} --help topics' to list all available topics.
EOF
}

parse_top_opt() {
    _t_count=""
    _t_filters=""

    for _t_arg in "$@"; do
        case "$_t_arg" in
            /*/)
                _t_filters="${_t_filters:+$_t_filters }$_t_arg"
                ;;
            '||'*)
                _t_filters="${_t_filters:+$_t_filters }$_t_arg"
                ;;
            ^*)
                _t_filters="${_t_filters:+$_t_filters }$_t_arg"
                ;;
            .*)
                _t_filters="${_t_filters:+$_t_filters }$_t_arg"
                ;;
            *[!0-9]*)
                _t_filters="${_t_filters:+$_t_filters }$_t_arg"
                ;;
            ''|0)

                log 1 "${RED}invalid count value for ${L_GREY}-t${RED}/${L_GREY}--top${RED}: ${L_GREY}$_t_arg${N_C}"

                return 1
                ;;
            *)

                [ -z "$_t_count" ] || { log 1 "${RED}multiple count values supplied to ${L_GREY}-t${RED}/${L_GREY}--top${RED}: ${L_GREY}$_t_count and $_t_arg${N_C}"
                    return 1
                }

                _t_count="$_t_arg"
                ;;
        esac
    done

    [ -n "$_t_count" ] || { log 1 "${L_GREY}-t${RED}/${L_GREY}--top ${RED}requires a positive integer count argument${N_C}"
        return 1
    }

    printf '%s\n' "$_t_count"
    printf '%s\n' "$_t_filters"
    return 0
}

