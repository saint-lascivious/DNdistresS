do_install() {
    target="$1"

    is_valid_target_dir "$target" || { log 1 "${RED}invalid install path: ${L_GREY}$target${N_C}"

        exit_with_status 2

    }

    as_root_or_sudo -i "$target" -V "$_VERBOSITY"

    [ ! -t 2 ] || [ "$_VERBOSITY" -lt 3 ] || print_banner >&2

    service_directory="$(service_safe_directory)"

    mkdir -p "$target" "$SERVICE_DIR"

    log 4 "${GREY}ensured install directories exist: ${L_GREY}$target${GREY}, ${L_GREY}$SERVICE_DIR${N_C}"

    src="$(self_source_path)" || { log 1 "${RED}unable to resolve script path for installation${N_C}"

        exit_with_status 1

    }

    if need_cmd install; then

        install -m 0755 "$src" "$target/$UNIT_BASE"

        log 3 "${BLUE}installed: ${L_GREY}$target/$UNIT_BASE${N_C}"

        log 4 "${GREY}installed using 'install' command${N_C}"

    else

        cp "$src" "$target/$UNIT_BASE"

        chmod 0755 "$target/$UNIT_BASE"

        log 3 "${BLUE}installed: ${L_GREY}$target/$UNIT_BASE${N_C}"

        log 4 "${GREY}installed using 'cp' and 'chmod' commands${N_C}"

    fi

    write_service_unit "$SERVICE_DIR/${UNIT_BASE}.service" "$target/$UNIT_BASE" "$service_directory"

    log 3 "${BLUE}installed: ${L_GREY}$SERVICE_DIR/${UNIT_BASE}.service${N_C}"

    log 4 "${GREY}wrote service unit to ${L_GREY}$SERVICE_DIR/${UNIT_BASE}.service${N_C}"

    write_timer_unit "$SERVICE_DIR/${UNIT_BASE}.timer"

    log 3 "${BLUE}installed: ${L_GREY}$SERVICE_DIR/${UNIT_BASE}.timer${N_C}"

    log 4 "${GREY}wrote timer unit to ${L_GREY}$SERVICE_DIR/${UNIT_BASE}.timer${N_C}"

    systemctl_maybe daemon-reload

    systemctl_maybe reset-failed "${UNIT_BASE}.service" "${UNIT_BASE}.timer"

    systemctl_maybe enable --now "${UNIT_BASE}.timer"

    write_bash_completion "$COMPLETION_DIR/$COMPLETION_BASENAME"

    log 3 "${BLUE}installed: ${L_GREY}$COMPLETION_DIR/$COMPLETION_BASENAME${N_C}"

    log 4 "${GREY}wrote bash completion to ${L_GREY}$COMPLETION_DIR/$COMPLETION_BASENAME${N_C}"

    log 4 "${GREY}reloaded systemd daemon, cleared stale failed state, and enabled timer ${L_GREY}${UNIT_BASE}.timer${N_C}"




}

do_uninstall() {
    target="$1"

    is_valid_target_dir "$target" || { log 1 "${RED}invalid uninstall path: ${L_GREY}$target${N_C}"

        exit_with_status 2

    }

    as_root_or_sudo -u "$target" -V "$_VERBOSITY"

