SENT=0

stop_worker_pool() {
    mode="${1:-graceful}"
    log 4 "stop_worker_pool: mode=$mode workers='${WORKER_PIDS# }'"

    if [ "$WRITER_FD_OPEN" -eq 1 ]; then
        exec 4>&-
        WRITER_FD_OPEN=0
    fi

    if [ "$mode" = "force" ]; then

        for p in $WORKER_PIDS; do
            kill -TERM "$p" 2>/dev/null || true
        done

        for p in $WORKER_PIDS; do
            kill -KILL "$p" 2>/dev/null || true
        done

    fi

    for p in $WORKER_PIDS; do
        wait "$p" 2>/dev/null || true
    done

    WORKER_PIDS=""

    if [ -n "$QUEUE_FIFO" ]; then
        rm -f "$QUEUE_FIFO" 2>/dev/null || true
    fi
}

cleanup_all() {
    mode="${1:-graceful}"

    if [ "$CLEANED" -eq 0 ]; then
        CLEANED=1
        stop_worker_pool "$mode"
        rm -rf "$TMPDIR"
    fi

    log 4 "cleanup_all: mode=$mode"
}

on_abort() {
    trap - INT TERM HUP
    log 4 "on_abort: signal caught, forcing cleanup"
    cleanup_all force

    now_abort="$(now_ms)"
    run_ms=$((now_abort - SCRIPT_START))

    start_ms="${START_TS:-$now_abort}"
    elapsed_ms=$((now_abort - start_ms))
    sent="${SENT:-0}"

    if [ "$elapsed_ms" -gt 0 ]; then
        ach_qps="$(awk -v s="$sent" -v ms="$elapsed_ms" 'BEGIN { printf "%.2f", s / (ms / 1000) }')"
    else
        ach_qps="0"
    fi

    elapsed_human="$(format_runtime_ms "$elapsed_ms")"
    run_human="$(format_runtime_ms "$run_ms")"

    if [ -t 1 ] && [ "$_VERBOSITY" -gt 0 ]; then
        printf '\n%s\n' "${sent}q / ${elapsed_human} = ${ach_qps}qps, took ${run_human}." >&2
    fi

    exit 130
}

trap 'cleanup_all' EXIT
