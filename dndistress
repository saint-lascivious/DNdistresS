CACHE_AGE=0
FETCH_CACHE_TMP=""
FETCH_SOURCE_PATH=""

fetch_source() {
    dst="$1"

    FETCH_SOURCE_PATH=""

    if [ -n "$_FILE" ]; then

        log 3 "${BLUE}using local source: ${L_GREY}$_FILE${N_C}"

        FETCH_SOURCE_PATH="$_FILE"
        return 0
    fi

    if [ "$_SECONDS" -eq 0 ]; then

        log 3 "${BLUE}Downloading: ${L_GREY}$_URL${N_C}"

        log 4 "${GREY}fetch_source: cache disabled (_SECONDS=${L_GREY}0${GREY})${N_C}"

        download_file "$_URL" "$dst" || return 1

        case "$_URL" in
            *.zip)

                validate_zip_file "$dst" || {

                    log 1 "${RED}downloaded zip failed integrity check: ${L_GREY}$_URL${N_C}"

                    return 1
                }
                ;;
        esac

        FETCH_SOURCE_PATH="$dst"
        return 0
    fi

    mkdir -p "$_DIRECTORY" || {

        log 1 "${RED}failed to create cache directory: ${L_GREY}$_DIRECTORY${N_C}"

        return 1
    }

    key="$(cache_key "$_URL")"
    cache_raw="$_DIRECTORY/$key.raw"
    cache_stamp="$_DIRECTORY/$key.stamp"
    now="$(( $(now_ms) / 1000 ))"

    log 5 "${GREY}fetch_source: key=${L_GREY}$key ${GREY}cache_raw=${L_GREY}$cache_raw ${GREY}cache_stamp=${L_GREY}$cache_stamp ${GREY}now=${L_GREY}$now${N_C}"

    if [ -f "$cache_raw" ] && [ -f "$cache_stamp" ]; then
        cached_at="$(cat "$cache_stamp" 2>/dev/null || printf '0')"

        case "$cached_at" in
            ''|*[!0-9]*)
                cached_at=0
                ;;
        esac

        CACHE_AGE=$((now - cached_at))

        log 5 "${GREY}fetch_source: cache candidate age=${L_GREY}$CACHE_AGE ${GREY}ttl=${L_GREY}$_SECONDS${N_C}"

        if [ "$CACHE_AGE" -lt "$_SECONDS" ]; then

            log 5 "${GREY}fetch_source: cache hit${N_C}"

            FETCH_SOURCE_PATH="$cache_raw"
            return 0
        fi

        log 5 "${GREY}fetch_source: cache stale${N_C}"

    fi

    log 3 "${BLUE}Downloading: ${L_GREY}$_URL${N_C}"

    log 5 "${GREY}fetch_source: downloading to temp before promoting to cache${N_C}"

    cache_tmp="${cache_raw}.tmp.$$"
    FETCH_CACHE_TMP="$cache_tmp"

    download_file "$_URL" "$cache_tmp" || {

        rm -f "$cache_tmp"

        FETCH_CACHE_TMP=""
        return 1
    }

    case "$_URL" in
        *.zip)

            validate_zip_file "$cache_tmp" || {

                log 1 "${RED}downloaded zip failed integrity check, discarding: ${L_GREY}$_URL${N_C}"

                rm -f "$cache_tmp"

                FETCH_CACHE_TMP=""
                return 1
            }

            log 5 "${GREY}fetch_source: zip integrity okay${N_C}"

            ;;
    esac

    mv "$cache_tmp" "$cache_raw" || {

        log 1 "${RED}failed to promote download to cache: ${L_GREY}$_URL ${RED}-> ${L_GREY}$cache_raw${N_C}"

        rm -f "$cache_tmp"

        FETCH_CACHE_TMP=""
        return 1
    }

    FETCH_CACHE_TMP=""

    printf '%s\n' "$now" > "$cache_stamp" || {

        log 1 "${RED}failed to write cache stamp: ${L_GREY}$cache_stamp${N_C}"

        return 1
    }

    FETCH_SOURCE_PATH="$cache_raw"
    return 0
}

extract_domains() {

    awk -F',' -v fmt="$_FORMAT" -v col="$_COLUMN" '
        function norm(x) {
            gsub(/\r/, "", x)
            sub(/^[[:space:]]+/, "", x)
            sub(/[[:space:]]+$/, "", x)
            x=tolower(x)
            sub(/\.$/, "", x)
            return x
        }

        function is_domain(x, n, i, lab) {
            if (x == "") return 0

            if (length(x) > 253) return 0

            if (x ~ /\.\./) return 0

            n=split(x, a, ".")

            for (i=1; i<=n; i++) {
                lab=a[i]

                if (lab == "") return 0

                if (length(lab) > 63) return 0

                if (lab !~ /^[a-z0-9-]+$/) return 0

                if (lab ~ /^-/ || lab ~ /-$/) return 0
            }

            return 1
        }

        {
            d=""

            if (fmt == "plain") {
                d=norm($0)

                if (is_domain(d)) print d

                next
            }

            if (col > 0) {

                if (col <= NF) {
                    d=norm($col)

                    if (is_domain(d)) print d

                }

                next
            }

            if (NF == 1) {
                d=norm($1)

                if (is_domain(d)) {
                    print d
                    next
                }

            }

            if ($1 ~ /^[0-9]+$/ && NF >= 2) {
                d=norm($2)

                if (is_domain(d)) {
                    print d
                    next
                }

            }

            for (i=1; i<=NF; i++) {
                d=norm($i)

                if (is_domain(d) && d !~ /^[0-9]+$/) {
                    print d
                    break
                }

            }

        }
    '

}

extract_custom_domains() {

    awk '
        function norm(x) {
            gsub(/\r/, "", x)
            sub(/[[:space:]]*#.*$/, "", x)
            sub(/^[[:space:]]+/, "", x)
            sub(/[[:space:]]+$/, "", x)
            x=tolower(x)
            sub(/\.$/, "", x)
            return x
        }

        function is_domain(x, n, i, lab) {
            if (x == "") return 0

            if (length(x) > 253) return 0

            if (x ~ /\.\./) return 0

            n=split(x, a, ".")

            for (i=1; i<=n; i++) {
                lab=a[i]

                if (lab == "") return 0

                if (length(lab) > 63) return 0

                if (lab !~ /^[a-z0-9-]+$/) return 0

                if (lab ~ /^-/ || lab ~ /-$/) return 0
            }

            return 1
        }

        {
            d=norm($0)

            if (d == "") next

            if (is_domain(d)) print d

        }
    '

}

choose_tool() {

    case "$_BINARY" in
        auto)

            if need_cmd dig; then
                _BINARY="dig"
            elif need_cmd nslookup; then
                _BINARY="nslookup"
            else

                log 1 "${RED}need dig or nslookup for querying${N_C}"

                return 1
            fi

            ;;
        dig)

            need_cmd dig || { log 1 "${RED}dig not found${N_C}"; return 1; }

            ;;
        nslookup)

            need_cmd nslookup || { log 1 "${RED}nslookup not found${N_C}"; return 1; }

            ;;
        *)

            log_invalid_enum "_BINARY" "$_BINARY" auto dig nslookup

