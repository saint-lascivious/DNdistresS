        log 5 "${GREY}stop_worker_pool: mode=${L_GREY}$mode ${GREY}workers:${L_GREY}$w${N_C}"

        if [ "$mode" = "graceful" ]; then
            i=0

            for f in $WORKER_FIFOS; do

                if [ "$i" -lt "$WORKER_COUNT" ] && [ -e "$f" ]; then
                    printf '%s\n' "$WORKER_STOP_TOKEN" > "$f" 2>/dev/null || true
                fi

                i=$((i + 1))
            done

        fi

        if [ "$mode" = "force" ]; then

            for p in $WORKER_PIDS; do

                log 5 "${GREY}stop_worker_pool: sending TERM to pid=${L_GREY}$p${N_C}"

                kill -TERM "$p" 2>/dev/null || true
            done

            for p in $WORKER_PIDS; do

                log 5 "${GREY}stop_worker_pool: sending KILL to pid=${L_GREY}$p${N_C}"

                kill -KILL "$p" 2>/dev/null || true
            done

        fi

        for p in $WORKER_PIDS; do

            log 5 "${GREY}stop_worker_pool: waiting for pid=${L_GREY}$p${N_C}"

            wait "$p" 2>/dev/null || true
        done

        WORKER_PIDS=""

        for f in $WORKER_FIFOS; do

            [ -e "$f" ] && log 5 "${GREY}stop_worker_pool: removing worker fifo ${L_GREY}$f${N_C}"

            rm -f "$f" 2>/dev/null || true

        done

        WORKER_FIFOS=""
        WORKER_COUNT=0
        WORKER_NEXT=0
    }

    cleanup_all() {
        print_success() {
            if [ -t 2 ] && [ "$_VERBOSITY" -ge 1 ]; then
                printf '%b\n' "${L_GREY}[${GREEN}✓${L_GREY}] ${BOLD}${GREEN}done!${N_C}"
            fi
        }

        mode="${1:-graceful}"

        if [ "$CLEANED" -eq 0 ]; then
            CLEANED=1

            log 5 "${GREY}cleanup_all: begin mode=${L_GREY}$mode${N_C}"

            if [ -n "${FETCH_CACHE_TMP:-}" ]; then

                log 5 "${GREY}cleanup_all: removing pending fetch temp ${L_GREY}$FETCH_CACHE_TMP${N_C}"

                rm -f "$FETCH_CACHE_TMP" 2>/dev/null || true

                FETCH_CACHE_TMP=""
            fi

            stop_worker_pool "$mode"

            exec 3<&- || true

            if [ -n "${TMPDIR:-}" ]; then

                if [ -d "$TMPDIR" ]; then

                    log 5 "${GREY}cleanup_all: removing temp dir ${L_GREY}$TMPDIR${N_C}"

                    rm -fr "$TMPDIR" 2>/dev/null || {

                        log 2 "${YELLOW}cleanup_all: temp dir not empty, retrying${N_C}"

                        sleep 0.1

                        rm -fr "$TMPDIR" 2>/dev/null || log 1 "${RED}cleanup_all: failed to remove temp dir ${L_GREY}$TMPDIR${RED}${N_C}"

                    }

                else

                    log 5 "${GREY}cleanup_all: temp dir already absent ${L_GREY}$TMPDIR${N_C}"

                fi

            fi

            log 5 "${GREY}cleanup_all: complete mode=${L_GREY}$mode${N_C}"

            print_success

            return 0
        fi

        log 5 "${GREY}cleanup_all: already cleaned; skipping (mode=${L_GREY}$mode${GREY})${N_C}"

        print_success

        return 0
    }

    runtime_report() {
        v="${1:-$_VERBOSITY}"

        compute_runtime_metrics

        ACTIVE_HUMAN="$(format_runtime_ms "$active_ms")"
        QUERIES_WINDOW_HUMAN="$(format_runtime_ms "$queries_window_ms")"
        SCRIPT_WINDOW_HUMAN="$(format_runtime_ms "$script_window_ms")"

        blocked_line() {

            if [ "$BLOCKED" -gt 0 ]; then
                printf '%b[%b•%b] %bBlocked (%b0.0.0.0%b): %b%s %b(%b%s%%%b)\n' \
                    "$L_GREY" "$GREY" "$L_GREY" \
                    "$GREY" "$L_GREY" "$GREY" "$L_GREY" \
                    "$BLOCKED" "$GREY" "$L_GREY" "$BLOCK_PCT" \
                    "$GREY"
            fi

        }

        nxdomain_line() {

            if [ "$NXDOMAIN" -gt 0 ]; then
                printf ' %b[%b•%b] %bNXDOMAIN:         %b%s %b(%b%s%%%b)\n' \
                    "$L_GREY" "$GREY" "$L_GREY" \
                    "$GREY" "$L_GREY" "$NXDOMAIN" "$GREY" \
                    "$L_GREY" "$NXDOMAIN_PCT" "$GREY"
            fi

        }

        if [ "$v" -ge 4 ]; then
            printf '%b[%b•%b] %bScript start:%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" \
                "$(date -d "@$((SCRIPT_START/1000))" "+%F %T" 2>/dev/null || date -r $((SCRIPT_START/1000)) 2>/dev/null)" \
                "$N_C"
            printf '%b[%b•%b] %bQueries start:%b     %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" \
                "$(date -d "@$((queries_start/1000))" "+%F %T" 2>/dev/null || date -r $((queries_start/1000)) 2>/dev/null)" \
                "$N_C"
            printf '%b[%b•%b] %bLast query sent:%b   %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" \
                "$(date -d "@$((last_sent_ms/1000))" "+%F %T" 2>/dev/null || date -r $((last_sent_ms/1000)) 2>/dev/null)" \
                "$N_C"
            printf '%b[%b•%b] %bScript end:%b        %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" \
                "$(date -d "@$((end_ms/1000))" "+%F %T" 2>/dev/null || date -r $((end_ms/1000)) 2>/dev/null)" \
                "$N_C"
            printf '%b[%b•%b] %bTotal runtime:%b     %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$SCRIPT_WINDOW_HUMAN" "$N_C"
            printf '%b[%b•%b] %bQuery window:%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$QUERIES_WINDOW_HUMAN" "$N_C"
            printf '%b[%b•%b] %bActive query time:%b %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$ACTIVE_HUMAN" "$N_C"
            printf '%b[%b•%b] %bQueries sent:%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$sent" "$N_C"

            blocked_line

            nxdomain_line

            printf '%b[%b•%b] %bQPS (active):%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$ach_qps" "$N_C"
            printf '%b[%b•%b] %bQPS (total):%b       %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$total_qps" "$N_C"
        elif [ "$v" -ge 3 ]; then
            printf '%b[%b•%b] %bTotal runtime:%b     %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$SCRIPT_WINDOW_HUMAN" "$N_C"
            printf '%b[%b•%b] %bQuery window:%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$QUERIES_WINDOW_HUMAN" "$N_C"
            printf '%b[%b•%b] %bActive query time:%b %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$ACTIVE_HUMAN" "$N_C"
            printf '%b[%b•%b] %bQueries sent:%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$sent" "$N_C"

            blocked_line

            nxdomain_line

            printf '%b[%b•%b] %bQPS:%b               %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$ach_qps" "$N_C"
        elif [ "$v" -ge 2 ]; then
            printf '%b[%b•%b] %bTotal runtime:%b     %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$SCRIPT_WINDOW_HUMAN" "$N_C"
            printf '%b[%b•%b] %bQueries sent:%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$sent" "$N_C"

            blocked_line

            nxdomain_line

            printf '%b[%b•%b] %bQPS:%b               %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$ach_qps" "$N_C"
        elif [ "$v" -ge 1 ]; then
            printf '%b[%b•%b] %bTotal runtime:%b     %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$SCRIPT_WINDOW_HUMAN" "$N_C"
            printf '%b[%b•%b] %bQueries sent:%b      %b%s%b\n' \
                "$L_GREY" "$GREY" "$L_GREY" "$GREY" "$N_C" \
                "$L_GREY" "$sent" "$N_C"
        fi

    }

    on_abort() {
        trap - INT TERM HUP
        trap - EXIT

        log 4 "${GREY}on_abort: signal caught, forcing cleanup${N_C}"

        cleanup_all force

        END_MS="$(now_ms)"

        if [ -t 2 ] && [ "$_VERBOSITY" -gt 0 ]; then

            runtime_report

        fi

        exit_with_status 130

    }

    trap 'cleanup_all' EXIT
    trap 'on_abort' INT TERM HUP

    RAW="$TMPDIR/raw"
    DOMAINS="$TMPDIR/domains.txt"
    MAIN_DOMAINS="$TMPDIR/main_domains.txt"
    SRC_NAME="${_FILE:-$_URL}"

    fetch_source "$RAW"

    READ_SOURCE="${FETCH_SOURCE_PATH:-$RAW}"

    case "$SRC_NAME" in
        *.zip)

            need_cmd unzip || { log 1 "${RED}unzip required for zip sources${N_C}"
                exit 1
            }

            ZIP_EXTRACT="$TMPDIR/unzipped.txt"

            validate_zip_file "$READ_SOURCE" || { log 1 "${RED}zip integrity check failed: ${L_GREY}$SRC_NAME${N_C}"
                exit 1
            }

            extract_zip_to_file "$READ_SOURCE" "$ZIP_EXTRACT" || { log 1 "${RED}failed to extract zip source: ${L_GREY}$SRC_NAME${N_C}"
                exit 1
            }

            extract_domains < "$ZIP_EXTRACT" > "$MAIN_DOMAINS"

            log 3 "${BLUE}extracted domains from zip source${N_C}"

            ;;
        *)

            extract_domains < "$READ_SOURCE" > "$MAIN_DOMAINS"

            log 3 "${BLUE}extracted domains from source${N_C}"

            ;;
    esac

    {

        if [ -r "$_CUSTOM" ]; then

            log 3 "${BLUE}using custom source: ${L_GREY}$_CUSTOM${N_C}"

            extract_custom_domains < "$_CUSTOM"

        elif [ "$SEEN_C" -eq 1 ]; then

            log 2 "${YELLOW}custom source not readable, skipping: ${L_GREY}$_CUSTOM${N_C}"

        fi

    cat "$MAIN_DOMAINS"
    } | awk \
        -v filters="$_TOP_FILTERS" \
        -v top="$_TOP" \
        -v v="$_VERBOSITY" \
        -v GREY="$GREY" \
        -v N_C="$N_C" \
        -v L_GREY="$L_GREY" '
        function emit_domain(d) {
            out_count++

            if (dbg_trace) {
                printf " %s[%s•%s] %stop domain: %s%s %s(%s%d%s)%s\n", L_GREY, GREY, L_GREY, \
                    GREY, L_GREY, d, GREY, L_GREY, out_count, GREY, \
                    N_C > "/dev/stderr"
            }

            print d

            if (out_count >= top) exit
        }

        BEGIN {
            nf = 0
            out_count = 0
            dbg_trace = ((v + 0) >= 5)

            if (filters != "") {
                n = split(filters, raw, " ")

                for (i = 1; i <= n; i++) {
                    pat = raw[i]

                    if (pat == "") continue

                    nf++
                    ftype[nf] = ""
                    fpat[nf]  = pat

                    if (pat ~ /^\/.*\/$/) {
                        ftype[nf] = "regex"
                        fpat[nf]  = substr(pat, 2, length(pat) - 2)
                    } else if (substr(pat, 1, 2) == "||") {
                        ftype[nf] = "anchor"
                        fpat[nf]  = substr(pat, 3)
                        gsub(/\./, "\\.", fpat[nf])
                        fpat[nf] = "(^|\\.)" fpat[nf] "$"
                    } else if (substr(pat, 1, 1) == "^") {
                        ftype[nf] = "prefix"
                        fpat[nf]  = substr(pat, 2)
                    } else if (substr(pat, 1, 1) == ".") {
                        ftype[nf] = "suffix"
                        fpat[nf]  = pat
                    } else {
                        ftype[nf] = "substr"
                    }
                }
            }
        }

        {
            d = $0

            if (nf == 0) {
                emit_domain(d)
                next
            }

            dlen = length(d)
            matched = 0

            for (i = 1; i <= nf; i++) {
                if (ftype[i] == "suffix") {
                    fl   = fpat[i]
                    flen = length(fl)

                    if (dlen >= flen && substr(d, dlen - flen + 1) == fl) {
                        matched = 1
                        break
                    }

                } else if (ftype[i] == "prefix") {

                    if (index(d, fpat[i]) == 1) {
                        matched = 1
                        break
                    }

                } else if (ftype[i] == "regex" || ftype[i] == "anchor") {

                    if (d ~ fpat[i]) {
                        matched = 1
                        break
                    }

                } else {
                    if (index(d, fpat[i]) > 0) {
                        matched = 1
                        break
                    }
                }
            }

            if (matched) emit_domain(d)
        }
    ' > "$DOMAINS"

    _DOMAINS="$(wc -l < "$DOMAINS" | tr -d ' ')"

    [ "$_DOMAINS" -gt 0 ] || { log 1 "${RED}no domains found in source after filtering${N_C}"
        exit 1
    }

    log 3 "${BLUE}got ${L_GREY}$_DOMAINS ${BLUE}domains from source${N_C}"

    MBUCKET=$((_BURST * 1000))
    MTOKENS="$MBUCKET"
    LAST_TS="$(now_ms)"
    START_TS="$LAST_TS"
    LAST_SENT_MS="$START_TS"
    DEBUG_TICK_MS="$START_TS"

    open_domains() {
        DOMAINS_EOF=0

        exec 3< "$DOMAINS" || {

            log 0 "${BOLD}${RED}failed to open domain list: ${L_GREY}$DOMAINS${N_C}"

            return 1
        }

    }

    next_domain() {

        if IFS= read -r CUR <&3; then
            DOMAINS_EOF=0
            return 0
        fi

        if [ "$_DURATION" -eq 0 ]; then
            exec 3<&-
            exec 3< "$DOMAINS"

            if IFS= read -r CUR <&3; then
                DOMAINS_EOF=0
                return 0
            fi
        fi

        DOMAINS_EOF=1
        return 1
    }

    open_domains || { log 0 "${BOLD}${RED}failed to open domain list: ${L_GREY}$DOMAINS${N_C}"
        exit 1
    }

    SLEEP_TINY_OK=0

    if sleep 0.01 2>/dev/null; then
        SLEEP_TINY_OK=1
    fi

    nap_for_tokens() {
        deficit_ms="${1:-1}"

        if [ "$SLEEP_TINY_OK" -eq 1 ]; then

            if [ "$deficit_ms" -le 10 ]; then

                sleep 0.01

            elif [ "$deficit_ms" -le 20 ]; then

                sleep 0.02

            elif [ "$deficit_ms" -le 50 ]; then

                sleep 0.05

            else

                sleep 0.1

            fi

        else

            sleep 1

        fi
    }

    start_worker_pool "$_MAXIMUM" || exit 1

    log 3 "${BLUE}worker pool size: ${L_GREY}$_MAXIMUM${N_C}"

    QUERIES_START=0

    if [ "$_RANDOM" -eq 1 ]; then

        init_random_rr_pool

        log 3 "${BLUE}random RR mode enabled with pool: ${L_GREY}$RANDOM_RR_POOL${N_C}"

    fi

    DURATION_MS=$((_DURATION * 1000))

    while :; do
        now_s="$(now_ms)"
        elapsed_ms=$((now_s - START_TS))

        if [ "$_DURATION" -gt 0 ] && [ "$elapsed_ms" -ge "$DURATION_MS" ]; then

            log 5 "${GREY}duration limit reached: ${L_GREY}${elapsed_ms}ms ${GREY}>= ${L_GREY}${DURATION_MS}ms${N_C}"

            break
        fi

        dt_ms=$((now_s - LAST_TS))

        if [ "$dt_ms" -gt 0 ]; then
            MTOKENS=$((MTOKENS + (_QPS * dt_ms)))

            [ "$MTOKENS" -gt "$MBUCKET" ] && MTOKENS="$MBUCKET"

            LAST_TS="$now_s"
        fi

        if [ $((now_s - DEBUG_TICK_MS)) -ge 1000 ]; then

            log 4 "${GREY}loop: elapsed_ms=${L_GREY}$elapsed_ms ${GREY}sent=${L_GREY}$SENT ${GREY}mtokens=${L_GREY}$MTOKENS${N_C}"

            DEBUG_TICK_MS="$now_s"
        fi

        if [ "$MTOKENS" -lt 1000 ]; then
            deficit=$((1000 - MTOKENS))

            [ "$deficit" -lt 1 ] && deficit=1

            wait_ms=$(((deficit + _QPS - 1) / _QPS))

            [ "$wait_ms" -lt 1 ] && wait_ms=1

            nap_for_tokens "$wait_ms"

            continue
        fi

        next_domain || break

        d="$CUR"

        [ -n "$d" ] || continue

        pick_query_type

        qtype="$PICKED_QTYPE"

        if [ "$QUERIES_START" -eq 0 ]; then
            QUERIES_START="$(now_ms)"
        fi

        if ! enqueue_job "${qtype}|$d"; then

            log 0 "${BOLD}${RED}worker queue write failed for domain: ${L_GREY}$d${N_C}"

            break
        fi

        SENT=$((SENT + 1))
        LAST_SENT_MS="$(now_ms)"
        MTOKENS=$((MTOKENS - 1000))
    done

    if [ "$DOMAINS_EOF" -eq 1 ]; then

        log 3 "${BLUE}domain list exhausted${N_C}"

        log 5 "${GREY}ending query loop${N_C}"

    fi

    exec 3<&-

    stop_worker_pool

    END_MS="$(now_ms)"

    if [ -t 2 ] && [ "$_VERBOSITY" -gt 0 ]; then

        runtime_report

    fi
}

if [ "${DNDISTRESS_TEST_MODE:-0}" != "1" ]; then

    do_dndistress "$@"

fi
