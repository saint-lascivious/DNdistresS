usage() {

    [ "$_VERBOSITY" -ge 3 ] && print_banner

    prog_name="${0##*/}"

    awk -v prog="$prog_name" -v syn="$SYNOPSIS" -v cols="${COLUMNS:-80}" '
        BEGIN {
            print "Usage:"
            head = "  " prog " "
            ind  = sprintf("%" length(head) "s", "")
            line = head
            s    = syn
            while (match(s, /\[[^]]+\]/)) {
                tok = substr(s, RSTART, RLENGTH)
                s   = substr(s, RSTART + RLENGTH)
                cand = (line == head) ? line tok : line " " tok
                if (length(cand) + 2 > cols) {
                    printf "%s \\\n", line
                    line = ind tok
                } else {
                    line = cand
                }
            }
            print line
            print ""
            print "  " prog " --help [topic]"
            print "  " prog " help [topic]"
            print "  " prog " install [PATH]"
            print "  " prog " uninstall [PATH]"
            print "  " prog " show {w|c|warranty|conditions}"
            print "  " prog " --show {w|c|warranty|conditions}"
            print "  " prog " --show-warranty"
            print "  " prog " --show-conditions"
        }
    '

    cat <<EOF

Help:
  -h, --help [topic]

  help [topic]
      Show help for a specific topic. Topic can be a command or option.

      Reverse parsing is supported (examples):
        ${0##*/} --help --install
        ${0##*/} --install --help
        ${0##*/} --help -q
        ${0##*/} -q --help

Topic examples:
  general, info, description, runtime, resolver, install, uninstall, show, version,
  binary, burst, column, custom, directory, duration, file, format,
  local, location, maximum, output, port, qps, remote, seconds,
  top, type, url, verbosity

Tip:
  Run '${0##*/} --help topics' to list all available topics.
EOF
}

